// иҜ„и®әеҢәйўңиүІйҮҚзҪ®
.gt-container
  .gt-ico-tip
    &::after
      content: 'гҖӮ( Win + . ) or ( вҢғ + вҢҳ + вҗЈ ) open Emoji'
      color: #999
  .gt-meta
    border-color var(--borderColor)!important
  .gt-comments-null
    color var(--textColor)
    opacity .5
  .gt-header-textarea
    color var(--textColor)
    background rgba(180,180,180,0.1)!important
  .gt-btn
    border-color $accentColor!important
    background-color $accentColor!important
  .gt-btn-preview
    background-color rgba(255,255,255,0)!important
    color $accentColor!important
  a
    color $accentColor!important
  .gt-svg svg
    fill $accentColor!important
  .gt-comment-content,.gt-comment-admin .gt-comment-content
    background-color rgba(150,150,150,0.1)!important
    &:hover
      box-shadow 0 0 25px rgba(150,150,150,.5)!important
    .gt-comment-body
      color var(--textColor)!important


// qqеҫҪз« 
.qq
  position: relative;
.qq::after
  content: "еҸҜж’©";
  background: $accentColor;
  color:#fff;
  padding: 0 5px;
  border-radius: 10px;
  font-size:12px;
  position: absolute;
  top: -4px;
  right: -35px;
  transform:scale(0.85);

// demoжЁЎеқ—еӣҫж ҮйўңиүІ
body .vuepress-plugin-demo-block__wrapper
  &,.vuepress-plugin-demo-block__display
    border-color rgba(160,160,160,.3)
  .vuepress-plugin-demo-block__footer:hover
    .vuepress-plugin-demo-block__expand::before
      border-top-color: $accentColor !important;
      border-bottom-color: $accentColor !important;
    svg
      fill: $accentColor !important;


// е…Ёж–ҮжҗңзҙўжЎҶ
.suggestions
  overflow: auto
  max-height: calc(100vh - 6rem)
  @media (max-width: 719px) {
    width: 90vw;
    min-width: 90vw!important;
    margin-right: -20px;
  }
  .highlight
    color: $accentColor
    font-weight: bold

.home-wrapper .banner .hero .actions.hero-actions-double
  display flex
  align-items center
  justify-content center
  flex-wrap wrap
  gap 12px
  .action-button
    margin 0
  .action-button.secondary
    color $accentColor
    background transparent
    border 1px solid $accentColor
    box-shadow none
    &:hover
      color #fff
      background $accentColor

.theme-container.toolbox-page,
.theme-container.linux-command-page
  .page
    @media (min-width 720px)
      padding-left 1rem !important
      padding-right 1rem !important
    > .theme-vdoing-wrapper
      max-width 1480px
      padding-left 1.5rem
      padding-right 1.5rem
      @media (max-width 959px)
        padding-left 1rem
        padding-right 1rem
  .content-wrapper
    width 100%
  .theme-vdoing-content
    max-width none
    width 100%
  h1
    max-width none
